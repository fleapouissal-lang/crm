NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mot de passe PostgreSQL (Supabase → Settings → Database → Database password)
SUPABASE_DB_PASSWORD=your-database-password

# Pooler (recommandé — connexion directe db.* peut échouer sans IPv6)
# Région visible dans Supabase → Settings → Database → Connection string
SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres.[PROJECT_REF]

# Optionnel — URL complète (remplace SUPABASE_DB_PASSWORD)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Désactiver les migrations auto (CI sans accès DB)
# SKIP_DB_MIGRATE=true
